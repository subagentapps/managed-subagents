{
  "name": "@subagentapps/orchestrator",
  "version": "0.0.0",
  "description": "CLI orchestrator that dispatches work to web/CLI sessions, watches PRs, and gates merges. See PROJECT_PLAN.md.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "subagent-orchestrator": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.0",
    "@iarna/toml": "^2.2.5",
    "@octokit/rest": "^21.0.0",
    "better-sqlite3": "^11.0.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
